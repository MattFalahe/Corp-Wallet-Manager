{
  "name": "mattfalahe/corp-wallet-manager",
  "description": "CorpWallet Manager - SeAT plugin for corporation wallet tracking and predictions",
  "type": "seat-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Matt Falahe",
      "email": "mattfalahe@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0",
    "eveseat/web": "^5.0",
    "eveseat/services": "^5.0",
    "barryvdh/laravel-dompdf": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "CorpWalletManager\\": "src/",
      "CorpWalletManager\\Database\\Seeders\\": "src/database/seeders/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "CorpWalletManager\\CorpWalletManagerServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
